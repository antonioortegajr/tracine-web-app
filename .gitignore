.vscode/extensions.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# cache
.cache/

# typescript
*.tsbuildinfo
next-env.d.ts
